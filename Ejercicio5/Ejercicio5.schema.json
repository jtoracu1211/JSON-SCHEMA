{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ejercicio 5 JSON Schema DAM",
  "description": "Este es el ejercicio 5 de la relación",
  "type": "object",
  "properties": {
    "idPedido": {
      "type": "string",
      "maxLength": 7
    },
    "fecha": {
      "type": "string",
      "format": "date-time"
    },
    "cliente": {
      "type": "object",
      "properties": {
        "idCliente": {
          "type": "string"
        },
        "nombre": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "direccion": {
          "type": "object",
          "properties": {
            "calle": {
              "type": "string"
            },
            "ciudad": {
              "type": "string"
            },
            "codigoPostal": {
              "type": "string"
            },
            "pais": {
              "type": "string"
            }
          },
          "required": ["calle", "ciudad", "codigoPostal", "pais"],
          "additionalProperties": false
        }
      },
      "required": ["idCliente", "nombre", "email", "direccion"],
      "additionalProperties": false
    },
    "productos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "idProducto": {
            "type": "string"
          },
          "nombre": {
            "type": "string"
          },
          "cantidad": {
            "type": "number",
            "minimum": 1
          },
          "precioUnitario": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": ["idProducto", "nombre", "cantidad", "precioUnitario"],
        "additionalProperties": false
      },
      "minItems": 1,
      "uniqueItems": false
    },
    "estadoPedido": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": false
    },
    "totalPedido": {
      "type": "number",
      "minimum": 0
    }
  },
  "required": [
    "idPedido",
    "fecha",
    "cliente",
    "productos",
    "estadoPedido",
    "totalPedido"
  ],
  "additionalProperties": false,
  "patternProperties": {
    "^\\$": {}
  }
}
