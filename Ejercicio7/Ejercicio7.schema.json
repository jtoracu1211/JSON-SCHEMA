{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ejercicio 7",
  "description": "Este es el ejercicio 7 de la relación 4",
  "type": "object",
  "properties": {
    "notas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dia": {
            "type": "string",
            "pattern": "^(0[1-9]|[12][0-9]|3[01])/(0[1-9]|1[0-2])/(19|20)[0-9]{2}$"
          },
          "hora": {
            "type": "string",
            "pattern": "^[0-2]{1}[0-9]{1}:[0-5]{1}[0-9]{1}$"
          },
          "para": {
            "type": "object",
            "properties": {
              "correo": {
                "type": "string"
              },
              "nombre completo": {
                "type": "string"
              }
            },
            "required": ["correo", "nombre completo"]
          },
          "de": {
            "type": "object",
            "properties": {
              "correo": {
                "type": "string"
              },
              "nombre completo": {
                "type": "string"
              }
            },
            "required": ["correo", "nombre completo"]
          },
          "titulo": {
            "type": "string"
          },
          "contenido": {
            "type": "string"
          }
        },
        "required": ["para", "de", "titulo", "contenido"],
        "additionalProperties": false,
        "patternProperties": {
          "^\\$": {}
        }
      }
    }
  }
}
