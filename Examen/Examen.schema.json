{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ejercicio de examen sobre JSON SCHEMA",
  "type": "object",
  "properties": {
    "nombre": {
      "type": "string"
    },
    "direccion": {
      "type": "object",
      "properties": {
        "calle":{
            "type":"string"
        },
        "ciudad":{
            "type":"string"
        },
        "codigo_postal":{
            "type":"string",
            "pattern":"^[0-9]{5}$"
        }
      },
      "additionalProperties": false
    },
    "comandas":{
        "type":"array",
        "minItems": 1,
        "maxItems": 50,
        "items": {
            "type":"object",
            "properties": {
                "id":{
                    "type":"string",
                    "pattern": "^[A-C]{2}-[0-9]{3}#$"
                },
                "num_mesa":{
                    "type":"integer",
                    "minimum": 1,
                    "maximum": 30
                },
                "nombre_camarero":{
                    "type":"string",
                    "maxLength": 20
                },
                "estado":{
                    "type":"string",
                    "enum": ["pendiente","en preparación","servida"]
                },
                "platos":{
                    "type":"array",
                    "minItems": 1,
                    "maxItems": 10,
                    "items": {
                        "type":"object",
                        "properties": {
                            "nombre":{
                                "type":"string"
                            },
                            "precio":{
                                "type":"number",
                                "exclusiveMinimum": 0
                            },
                            "cantidad":{
                                "type":"integer",
                                "minimum": 1,
                                "maximum": 10
                            },
                            "extras":{
                                "type":"array",
                                "items": {
                                    "type":"string"
                                }
                            }
                        },
                        "required": ["nombre","precio","cantidad"],
                        "additionalProperties": false
                    }
                },
                "pago":{
                    "type":"object",
                    "properties": {
                        "metodo":{
                            "type":"string",
                            "enum":["efectivo","tarjeta","online"]
                        },
                        "importe_total":{
                            "type":"number",
                            "exclusiveMinimum": 0
                        }
                    },
                    "required": ["metodo","importe_total"],
                    "additionalProperties": false
                }
            },
            "required":["id","num_mesa","estado","platos"],
            "additionalProperties": false
        }
    }
  },
  "required": ["nombre", "direccion"],
  "additionalProperties": false,
  "patternProperties": {
    "^\\$": {}
  }
}
